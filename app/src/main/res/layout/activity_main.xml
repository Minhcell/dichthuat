<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/foreign_language"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spinnerLang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchBluetooth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/bluetooth_headset" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchSpeak"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:checked="true"
        android:text="Đọc to bản dịch (TTS)" />

    <TextView
        android:id="@+id/tvSilence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:text="⏱ Độ nhạy ngắt câu: 1,0 giây"
        android:textSize="13sp" />

    <SeekBar
        android:id="@+id/seekSilence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="15" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:text="Sẵn sàng"
        android:textColor="#1565C0" />

    <Button
        android:id="@+id/btnFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:backgroundTint="#6A1B9A"
        android:text="🎵 Dịch file ghi âm" />

    <Button
        android:id="@+id/btnClearLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:backgroundTint="#455A64"
        android:text="🗑 Xóa nội dung hội thoại" />

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F2F4F8"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <Button
            android:id="@+id/btnVi"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:backgroundTint="#2E7D32"
            android:text="@string/i_speak_vi" />

        <Button
            android:id="@+id/btnForeign"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:backgroundTint="#C62828"
            android:text="@string/other_speaks" />
    </LinearLayout>

    <Button
        android:id="@+id/btnMovie"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/open_movie_mode" />
</LinearLayout>
